rules_version = '2';

// Firestore security rules — Visualizador PAF
// Roles derivan del documento /usuarios/{uid}, campo perfilDefault.
// Perfiles con acceso completo: consultor, cap, superadmin.
// Perfiles con acceso limitado:
//   - escuela/jardin: solo su propio establecimiento (usuarios.establecimientoId)
//   - sostenedor: solo los establecimientos de su red (usuarios.slepId)
// Perfil 'pendiente': acceso restringido (solo puede leer su propio doc de usuario)

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────
    function esAuth() {
      return request.auth != null;
    }

    function getUsuario() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function existeUsuario() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function perfil() {
      return existeUsuario() ? getUsuario().perfilDefault : null;
    }

    // Usuario válido = autenticado, con doc en /usuarios y perfil asignado (no 'pendiente')
    function esUsuarioValido() {
      return esAuth() && existeUsuario() && perfil() != 'pendiente';
    }

    function esSuperadmin() {
      return esAuth() && existeUsuario() && perfil() == 'superadmin';
    }

    function esAccesoCompleto() {
      return esAuth() && existeUsuario() &&
        perfil() in ['consultor', 'cap', 'superadmin'];
    }

    function esEscuelaOJardin() {
      return esAuth() && existeUsuario() &&
        perfil() in ['escuela', 'jardin'];
    }

    function esSostenedor() {
      return esAuth() && existeUsuario() && perfil() == 'sostenedor';
    }

    // ─── /usuarios/{uid} ────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Cada usuario lee su propio doc; superadmin lee todos
      allow read: if esAuth() && (request.auth.uid == uid || esSuperadmin());
      // Registro inicial: cada usuario crea su propio doc
      allow create: if esAuth() && request.auth.uid == uid;
      // Update: el propio usuario (para cambios cosméticos) o superadmin
      allow update: if esAuth() && (request.auth.uid == uid || esSuperadmin());
      // Delete: solo superadmin
      allow delete: if esSuperadmin();
    }

    // ─── /sostenedores/{slepId} ─────────────────────────────────────────
    match /sostenedores/{slepId} {
      allow read: if esUsuarioValido();
      allow write: if esSuperadmin();
    }

    // ─── /establecimientos/{estId} ──────────────────────────────────────
    match /establecimientos/{estId} {
      allow read: if esUsuarioValido() && (
        // Escuela/jardin: solo su propio establecimiento
        (esEscuelaOJardin() && getUsuario().establecimientoId == estId) ||
        // Sostenedor: solo los de su red
        (esSostenedor() && resource.data.slep == getUsuario().slepId) ||
        // Consultor / CAP / superadmin: todos
        esAccesoCompleto()
      );
      allow write: if esSuperadmin();
    }

    // ─── /indicadores/{indicadorId} ─────────────────────────────────────
    match /indicadores/{indicadorId} {
      allow read: if esUsuarioValido();
      allow write: if esSuperadmin();
    }

    // ─── /ambitos/{docId} ───────────────────────────────────────────────
    match /ambitos/{docId} {
      allow read: if esUsuarioValido();
      allow write: if esSuperadmin();
    }

    // ─── /valores/{valorId} ─────────────────────────────────────────────
    match /valores/{valorId} {
      allow read: if esUsuarioValido();
      allow write: if false;
    }

    // ─── /progresoTrimestral/{docId} ─── Fase B: agregados por (est × ámbito × trimestre) ─
    match /progresoTrimestral/{docId} {
      allow read: if esUsuarioValido() && (
        (esEscuelaOJardin() && resource.data.establecimientoId == getUsuario().establecimientoId) ||
        esSostenedor() ||
        esAccesoCompleto()
      );
      allow write: if false;
    }

    // ─── /valoresIndicador/{docId} ─── Fase C: valores atómicos por indicador ─
    match /valoresIndicador/{docId} {
      allow read: if esUsuarioValido() && (
        (esEscuelaOJardin() && resource.data.establecimientoId == getUsuario().establecimientoId) ||
        esSostenedor() ||
        esAccesoCompleto()
      );
      allow write: if false;
    }

    // ─── /metadata/{docId} ──────────────────────────────────────────────
    match /metadata/{docId} {
      allow read: if esUsuarioValido();
      allow write: if esSuperadmin();
    }

    // ─── /config/{docId} — dataSource flag y config global (Etapa 4) ────
    // Lectura pública (el cliente lo consulta ANTES del login para decidir
    // qué fuente de datos usar). El flag no expone información sensible; sólo
    // dice si Escolar/Parvulario deben leer de sintético o de real.
    match /config/{docId} {
      allow read: if true;
      allow write: if esSuperadmin();
    }

    // ─── /establecimientos_real/{estId} — Etapa 3 ingesta real ─────────
    // Mismo modelo de visibilidad que /establecimientos.
    match /establecimientos_real/{estId} {
      allow read: if esUsuarioValido() && (
        (esEscuelaOJardin() && getUsuario().establecimientoId == estId) ||
        (esSostenedor() && resource.data.slep == getUsuario().slepId) ||
        esAccesoCompleto()
      );
      allow write: if false;   // sólo el pipeline (Admin SDK) escribe
    }

    // ─── /resultados_real/{docId} — Etapa 3/5 ingesta real ─────────────
    // Mismo modelo que /valoresIndicador.
    match /resultados_real/{docId} {
      allow read: if esUsuarioValido() && (
        (esEscuelaOJardin() && resource.data.establecimientoId == getUsuario().establecimientoId) ||
        esSostenedor() ||
        esAccesoCompleto()
      );
      allow write: if false;
    }

    // ─── /progresoTrimestral_real/{docId} ──────────────────────────────
    match /progresoTrimestral_real/{docId} {
      allow read: if esUsuarioValido() && (
        (esEscuelaOJardin() && resource.data.establecimientoId == getUsuario().establecimientoId) ||
        esSostenedor() ||
        esAccesoCompleto()
      );
      allow write: if false;
    }
  }
}
